[Desktop Entry]
Type=Application
Name=Next meeting
Comment=Show your next Google Calendar event in the COSMIC panel
Exec=cosmic-google-agenda-panel
Icon=io.github.cosmic_google_agenda_panel
Terminal=false
Categories=COSMIC;X-COSMIC-Applet;
NoDisplay=true
X-CosmicApplet=true
X-CosmicHoverPopup=Auto
X-OverflowPriority=2
